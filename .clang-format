DisableFormat: true
BasedOnStyle: LLVM

ColumnLimit: 100                  # LLVM uses 80
IndentWidth: 4                    # LLVM uses 2
TabWidth: 4                       # LLVM uses 8
PointerAlignment: Left            # LLVM uses Right
SpacesBeforeTrailingComments: 2   # LLVM uses 1

Cpp11BracedListStyle: false

KeepEmptyLines:
    AtEndOfFile:     false
    AtStartOfBlock:  true
    AtStartOfFile:   true

AllowShortBlocksOnASingleLine: Never
AlignConsecutiveDeclarations: true
AllowShortFunctionsOnASingleLine: InlineOnly
BreakTemplateDeclarations: Yes
SortIncludes: Never
BreakConstructorInitializers: BeforeComma
PackConstructorInitializers: CurrentLine
